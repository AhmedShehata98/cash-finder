APP_ENV=development
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key

# Server-only Supabase Edge Function secret. Never use EXPO_PUBLIC_ for this key.
# Hosted: supabase secrets set HERE_API_KEY=your_here_maps_api_key
# Local: copy supabase/functions/.env.example to supabase/functions/.env
